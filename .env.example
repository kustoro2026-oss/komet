# ============================================================
# Komet - Environment Variables
# Copy this file to .env.local and fill in your values
# ============================================================

# --- Supabase (Database + Auth + Storage) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- App Configuration ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- OpenAI (AI Content Generation) ---
OPENAI_API_KEY=sk-your-openai-api-key

# --- Zernio (Social Media Engine) ---
ZERNIO_API_KEY=your-zernio-api-key

# --- Resend (Email Service) ---
RESEND_API_KEY=re_your-resend-api-key

# --- Upstash Redis (Caching) ---
UPSTASH_REDIS_REST_URL=https://your-region.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# --- PayPal (Payment Gateway) ---
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret
PAYPAL_API_URL=https://api-m.sandbox.paypal.com

# --- Duitku (Payment Gateway - Indonesia) ---
DUITKU_MERCHANT_CODE=your-merchant-code
DUITKU_API_KEY=your-duitku-api-key
DUITKU_API_URL=https://api-sandbox.duitku.com

# --- Inngest (Background Jobs) ---
INNGEST_EVENT_KEY=your-inngest-event-key

# --- OAuth Credentials for Social Media Platforms ---
# Get these from each platform's developer portal

# Twitter / X (OAuth 2.0 PKCE)
TWITTER_CLIENT_ID=your-twitter-client-id
TWITTER_CLIENT_SECRET=your-twitter-client-secret
# X API App-only Bearer Token (for XAA webhook + subscription management)
TWITTER_BEARER_TOKEN=your-twitter-bearer-token
# X API OAuth 1.0a Consumer Secret (for CRC HMAC signature verification)
TWITTER_CONSUMER_SECRET=your-twitter-api-secret-key

# Instagram (Meta / Facebook Login)
INSTAGRAM_CLIENT_ID=your-instagram-client-id
INSTAGRAM_CLIENT_SECRET=your-instagram-client-secret

# Facebook (Facebook Login / Graph API)
FACEBOOK_CLIENT_ID=your-facebook-client-id
FACEBOOK_CLIENT_SECRET=your-facebook-client-secret

# LinkedIn (OAuth 2.0)
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret

# YouTube (Google OAuth 2.0)
YOUTUBE_CLIENT_ID=your-youtube-client-id
YOUTUBE_CLIENT_SECRET=your-youtube-client-secret

# Threads (Meta / Threads API)
THREADS_CLIENT_ID=your-threads-client-id
THREADS_CLIENT_SECRET=your-threads-client-secret

# TikTok (OAuth 2.0)
TIKTOK_CLIENT_ID=your-tiktok-client-id
TIKTOK_CLIENT_SECRET=your-tiktok-client-secret

# Pinterest (OAuth 2.0)
PINTEREST_CLIENT_ID=your-pinterest-client-id
PINTEREST_CLIENT_SECRET=your-pinterest-client-secret

# Reddit (OAuth 2.0)
REDDIT_CLIENT_ID=your-reddit-client-id
REDDIT_CLIENT_SECRET=your-reddit-client-secret

# Discord (OAuth 2.0 + webhook.incoming)
DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_CLIENT_SECRET=your-discord-client-secret

# Snapchat (Snap Kit OAuth)
SNAPCHAT_CLIENT_ID=your-snapchat-client-id
SNAPCHAT_CLIENT_SECRET=your-snapchat-client-secret

# LinkedIn (OAuth 2.0)
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret

# Google Business Profile (Google OAuth 2.0)
GOOGLE_BUSINESS_CLIENT_ID=your-google-business-client-id
GOOGLE_BUSINESS_CLIENT_SECRET=your-google-business-client-secret

# WhatsApp Business (Meta / WhatsApp Cloud API)
WHATSAPP_CLIENT_ID=your-whatsapp-client-id
WHATSAPP_CLIENT_SECRET=your-whatsapp-client-secret

# Telegram Userbot (MTProto login via phone number)
TELEGRAM_API_ID=your-telegram-api-id
TELEGRAM_API_HASH=your-telegram-api-hash
